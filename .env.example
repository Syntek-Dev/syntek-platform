# Django Core Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@db:5432/backend_template_dev
DB_NAME=backend_template_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# GraphQL Settings
GRAPHQL_PLAYGROUND_ENABLED=True
GRAPHQL_INTROSPECTION_ENABLED=True

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=True

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025

# Media and Static Files
MEDIA_URL=/media/
STATIC_URL=/static/

# Redis Cache (optional)
REDIS_URL=redis://redis:6379/0

# Celery (optional)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Security Settings
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_AGE=1209600

# Rate Limiting (requests per minute)
RATELIMIT_ENABLE_IN_DEBUG=False
RATELIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATELIMIT_GRAPHQL_MUTATION_REQUESTS_PER_MINUTE=30
RATELIMIT_GRAPHQL_QUERY_REQUESTS_PER_MINUTE=100
RATELIMIT_API_REQUESTS_PER_MINUTE=60
RATELIMIT_DEFAULT_REQUESTS_PER_MINUTE=120

# GraphQL Security
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_COMPLEXITY=1000
GRAPHQL_ENABLE_INTROSPECTION=True

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/app
LOG_JSON_FORMAT=False

# =============================================================================
# Phase 7: Audit Logging and Security
# =============================================================================

# Audit Log Retention (H7)
# Number of days to keep audit logs before archiving/deletion
AUDIT_LOG_RETENTION_DAYS=90

# Concurrent Session Management (M7)
# Maximum number of active sessions per user
# When exceeded, oldest session is automatically terminated
MAX_CONCURRENT_SESSIONS_PER_USER=5

# Session idle timeout in hours (sessions inactive longer are cleaned up)
SESSION_IDLE_TIMEOUT_HOURS=24

# Failed Login Tracking (M9)
# Progressive lockout with exponential backoff
# Lockout durations: 5min (3-5 failures), 15min (6-10), 1hr (11-20), 24hr (21+)
FAILED_LOGIN_LOCKOUT_ENABLED=True

# Suspicious Activity Detection (M10)
# Email address used for security alert notifications
SECURITY_EMAIL_FROM=security@example.com

# Number of days to remember known IP addresses for new location detection
KNOWN_IP_RETENTION_DAYS=30

# Enable/disable specific security alerts
ALERT_ON_NEW_LOCATION_LOGIN=True
ALERT_ON_PASSWORD_CHANGE=True
ALERT_ON_2FA_CHANGE=True
ALERT_ON_ACCOUNT_LOCKOUT=True
