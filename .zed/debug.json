  {
    "label": "Python: Attach to Remote Debugger",
    "adapter": "Debugpy",
    "request": "attach",
    "host": "localhost",
    "port": 5678,
    "pathMappings": [
      {
        "localRoot": "$ZED_WORKTREE_ROOT",
        "remoteRoot": "/app"
      }
    ]
  },
