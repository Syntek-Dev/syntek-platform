[
  // ============================================
  // DJANGO SERVER
  // ============================================
  {
    "label": "Django: Runserver (Dev)",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
    "args": ["runserver", "0.0.0.0:8000", "--noreload"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "console": "integratedTerminal",
    "django": true,
    "justMyCode": false,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.dev"
    }
  },
  {
    "label": "Django: Runserver (Test Settings)",
    "adapter": "Debugpy",
    "request": "launch",
    "program": "${ZED_WORKTREE_ROOT}/manage.py",
