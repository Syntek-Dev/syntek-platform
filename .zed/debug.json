    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.test"
    }
  },
  {
    "label": "Pytest: All Tests with Coverage",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "pytest",
    "args": ["-v", "-s", "--cov=.", "--cov-report=term-missing"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "console": "integratedTerminal",
    "justMyCode": false,
    "env": {
      "DJANGO_SETTINGS_MODULE": "config.settings.test"
    }
  },
