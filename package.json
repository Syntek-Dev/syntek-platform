{
  "name": "backend-template",
  "version": "0.9.0",
  "description": "Django backend with PostgreSQL and GraphQL API",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check . && markdownlint-cli2 '**/*.md' '#node_modules' '#.venv'",
    "lint": "npm run lint:prettier && npm run lint:markdown",
    "lint:prettier": "prettier --check .",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules' '#.venv'",
    "lint:markdown:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#.venv'"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.4.2",
    "prettier-plugin-jinja-template": "^2.0.0"
  },
  "keywords": [
    "django",
    "graphql",
    "postgresql",
    "backend",
    "api",
    "cms"
  ],
  "author": "Syntek Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syntek-studio/backend-template"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.7.0"
  }
}
