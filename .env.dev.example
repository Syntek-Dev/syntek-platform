# Development Environment Variables
# Copy to .env.dev and update values

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=generate-with-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker container)
DATABASE_URL=postgres://backend_template:backend_template@db:5432/backend_template_dev

# Redis (Docker container)
REDIS_URL=redis://redis:6379/0

# Email (Mailpit)
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# GraphQL
GRAPHQL_DEBUG=True

# =============================================================================
# Sentry (Optional in Development)
# =============================================================================
# You can optionally enable Sentry in development for testing the integration
# Leave SENTRY_DSN empty to disable

# Your Sentry DSN (optional - leave empty to disable in dev)
SENTRY_DSN=

# If enabled, use these settings:
SENTRY_ENVIRONMENT=development
SENTRY_SEND_PII=True
SENTRY_ENABLE_LOGS=True
SENTRY_LOG_LEVEL=10
SENTRY_EVENT_LEVEL=40
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_PROFILE_LIFECYCLE=trace

# Security Settings
SESSION_COOKIE_AGE=1209600
RATELIMIT_ENABLE_IN_DEBUG=False

# Rate Limiting Configuration
RATELIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATELIMIT_GRAPHQL_MUTATION_REQUESTS_PER_MINUTE=30
RATELIMIT_GRAPHQL_QUERY_REQUESTS_PER_MINUTE=100
RATELIMIT_API_REQUESTS_PER_MINUTE=60
RATELIMIT_DEFAULT_REQUESTS_PER_MINUTE=120

# IP Allowlist for Admin Areas (optional, leave empty to disable)
# Comma-separated list of IPs or CIDR ranges
# Example: "192.168.1.0/24,10.0.0.1,203.0.113.5"
# Leave empty in dev to allow all IPs
ADMIN_ALLOWED_IPS=

# Protected paths for IP allowlist (comma-separated)
# IP_ALLOWLIST_PROTECTED_PATHS="/admin/,/cms/admin/,/api/admin/"

# GraphQL Security
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_COMPLEXITY=1000
GRAPHQL_ENABLE_INTROSPECTION=True

# Encryption and Signing Keys - C1, C2 Security Requirements
# TOKEN_SIGNING_KEY: HMAC-SHA256 key for token hashing (C1 requirement)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SIGNING_KEY=

# TOTP_ENCRYPTION_KEY: Fernet key for 2FA secrets (C2 requirement)
# IP_ENCRYPTION_KEY: Fernet key for IP address encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Use DIFFERENT keys for each environment (dev, test, staging, production)
TOTP_ENCRYPTION_KEY=
IP_ENCRYPTION_KEY=

# ClickUp Project Management Integration
# Get your API key from: https://app.clickup.com/settings/apps
# NEVER commit actual values - keep them in .env.dev (gitignored)
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_BACKLOG_FOLDER_ID=
CLICKUP_SPRINT_FOLDER_ID=
CLICKUP_BACKLOG_LIST_ID=

# Phase 4: Security Hardening - Password & Bot Protection

# HaveIBeenPwned Integration (C001) - Password Breach Detection
# Checks passwords against known data breaches using k-anonymity model
# Set to False to disable (not recommended in production)
HIBP_API_ENABLED=true
HIBP_BREACH_THRESHOLD=3

# reCAPTCHA v3 (M001) - Bot Protection
# Get keys from: https://www.google.com/recaptcha/admin
# Site key is public, secret key must be kept confidential
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_REGISTER=0.5
RECAPTCHA_SCORE_LOGIN=0.3

# Password Reset Token Configuration (M007)
# Token expiry in minutes (reduced from 15 to 10 minutes for security)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10

# =============================================================================
# Phase 7: Audit Logging and Security
# =============================================================================

# Logging Configuration
# Directory for log files (auth.log, mail.log, database.log, security.log, graphql.log, app.log)
LOG_DIR=/var/log/app
LOG_LEVEL=DEBUG
# Use JSON format for logs (True for production log aggregation, False for human-readable dev logs)
LOG_JSON_FORMAT=False
# Log file rotation settings
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Audit Log Retention (H7)
# Number of days to keep audit logs before archiving/deletion
AUDIT_LOG_RETENTION_DAYS=90

# Concurrent Session Management (M7)
# Maximum number of active sessions per user
# When exceeded, oldest session is automatically terminated
MAX_CONCURRENT_SESSIONS_PER_USER=5

# Session idle timeout in hours (sessions inactive longer are cleaned up)
SESSION_IDLE_TIMEOUT_HOURS=24

# Failed Login Tracking (M9)
# Progressive lockout with exponential backoff
# Lockout durations: 5min (3-5 failures), 15min (6-10), 1hr (11-20), 24hr (21+)
FAILED_LOGIN_LOCKOUT_ENABLED=True

# Suspicious Activity Detection (M10)
# Email address used for security alert notifications
SECURITY_EMAIL_FROM=security@localhost

# Number of days to remember known IP addresses for new location detection
KNOWN_IP_RETENTION_DAYS=30

# Enable/disable specific security alerts (can disable in dev for less noise)
ALERT_ON_NEW_LOCATION_LOGIN=False
ALERT_ON_PASSWORD_CHANGE=False
ALERT_ON_2FA_CHANGE=False
ALERT_ON_ACCOUNT_LOCKOUT=False
