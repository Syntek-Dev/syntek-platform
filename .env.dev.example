# Development Environment Variables
# Copy to .env.dev and update values

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=generate-with-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker container)
DATABASE_URL=postgres://backend_template:backend_template@db:5432/backend_template_dev

# Redis (Docker container)
REDIS_URL=redis://redis:6379/0

# Email (Mailpit)
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# GraphQL
GRAPHQL_DEBUG=True

# Security Settings
SESSION_COOKIE_AGE=1209600
RATELIMIT_ENABLE_IN_DEBUG=False

# Rate Limiting Configuration
RATELIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATELIMIT_GRAPHQL_MUTATION_REQUESTS_PER_MINUTE=30
RATELIMIT_GRAPHQL_QUERY_REQUESTS_PER_MINUTE=100
RATELIMIT_API_REQUESTS_PER_MINUTE=60
RATELIMIT_DEFAULT_REQUESTS_PER_MINUTE=120

# IP Allowlist for Admin Areas (optional, leave empty to disable)
# Comma-separated list of IPs or CIDR ranges
# Example: "192.168.1.0/24,10.0.0.1,203.0.113.5"
# Leave empty in dev to allow all IPs
ADMIN_ALLOWED_IPS=

# Protected paths for IP allowlist (comma-separated)
# IP_ALLOWLIST_PROTECTED_PATHS="/admin/,/cms/admin/,/api/admin/"

# GraphQL Security
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_COMPLEXITY=1000
GRAPHQL_ENABLE_INTROSPECTION=True

# Encryption and Signing Keys - C1, C2 Security Requirements
# TOKEN_SIGNING_KEY: HMAC-SHA256 key for token hashing (C1 requirement)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SIGNING_KEY=

# TOTP_ENCRYPTION_KEY: Fernet key for 2FA secrets (C2 requirement)
# IP_ENCRYPTION_KEY: Fernet key for IP address encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Use DIFFERENT keys for each environment (dev, test, staging, production)
TOTP_ENCRYPTION_KEY=
IP_ENCRYPTION_KEY=

# ClickUp Project Management Integration
# Get your API key from: https://app.clickup.com/settings/apps
# NEVER commit actual values - keep them in .env.dev (gitignored)
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_BACKLOG_FOLDER_ID=
CLICKUP_SPRINT_FOLDER_ID=
CLICKUP_BACKLOG_LIST_ID=
