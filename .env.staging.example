# Staging Environment Variables
# Copy to .env.staging and update values
# NEVER commit actual values to version control

# Django
DJANGO_SETTINGS_MODULE=config.settings.staging
SECRET_KEY=generate-a-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=staging.example.com

# Database (AWS RDS or Digital Ocean)
DATABASE_URL=postgres://user:password@host:5432/backend_template_staging

# Redis (Managed service)
REDIS_URL=redis://user:password@host:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# GraphQL
GRAPHQL_DEBUG=False

# Error Tracking
SENTRY_DSN=https://your-sentry-dsn

# Cloud Storage (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Security (mirror production settings for testing)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_AGE=3600

# Rate Limiting (requests per minute)
RATELIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATELIMIT_GRAPHQL_MUTATION_REQUESTS_PER_MINUTE=30
RATELIMIT_GRAPHQL_QUERY_REQUESTS_PER_MINUTE=100
RATELIMIT_API_REQUESTS_PER_MINUTE=60
RATELIMIT_DEFAULT_REQUESTS_PER_MINUTE=120

# GraphQL Security (introspection can be enabled for testing)
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_COMPLEXITY=1000
GRAPHQL_ENABLE_INTROSPECTION=True

# ClickUp Project Management Integration
# Get your API key from: https://app.clickup.com/settings/apps
# NEVER commit actual values - keep them in .env.staging (gitignored)
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_BACKLOG_FOLDER_ID=
CLICKUP_SPRINT_FOLDER_ID=
CLICKUP_BACKLOG_LIST_ID=
