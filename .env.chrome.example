# Browser Configuration for Testing
# Auto-detected Chrome paths for Selenium, Playwright, and Puppeteer

# Primary Chrome binary path
CHROME_PATH=

# Alternative names for framework compatibility
CHROME_BINARY=
DUSK_CHROME_BINARY=
PUPPETEER_EXECUTABLE_PATH=
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# Selenium WebDriver settings
SELENIUM_BROWSER=chrome
SELENIUM_HEADLESS=True

# ChromeDriver path (if using standalone ChromeDriver)
# CHROMEDRIVER_PATH=/usr/local/bin/chromedriver
