# Auto detect text files and perform LF normalisation
* text=auto

# Python source files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Django templates
*.html text eol=lf
*.txt text eol=lf
*.xml text eol=lf

# JavaScript/CSS for Django admin
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.json text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.flake8 text eol=lf
.pre-commit-config.yaml text eol=lf

# SQL files
*.sql text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf
docker-compose*.yml text eol=lf

# Binary files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.pyc binary

# Linguist overrides for GitHub
*.test.py linguist-detectable=false
*/migrations/*.py linguist-generated=true
*/tests/*.py linguist-detectable=false
