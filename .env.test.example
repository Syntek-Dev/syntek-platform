# Test Environment Variables
# Copy to .env.test and update values

# Django
DJANGO_SETTINGS_MODULE=config.settings.test
SECRET_KEY=generate-with-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker container - uses tmpfs for speed)
DATABASE_URL=postgres://backend_template:backend_template@db:5432/backend_template_test

# Redis (Docker container)
REDIS_URL=redis://redis:6379/1

# Email (Mailpit)
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@localhost

# GraphQL
GRAPHQL_DEBUG=False

# Encryption and Signing Keys - C1, C2 Security Requirements
# TOKEN_SIGNING_KEY: HMAC-SHA256 key for token hashing (C1 requirement)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SIGNING_KEY=

# TOTP_ENCRYPTION_KEY: Fernet key for 2FA secrets (C2 requirement)
# IP_ENCRYPTION_KEY: Fernet key for IP address encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Use DIFFERENT keys for each environment (dev, test, staging, production)
TOTP_ENCRYPTION_KEY=
IP_ENCRYPTION_KEY=

# Phase 4: Security Hardening - Password & Bot Protection

# HaveIBeenPwned Integration (C001) - Disabled in tests for speed
HIBP_API_ENABLED=false
HIBP_BREACH_THRESHOLD=3

# reCAPTCHA v3 (M001) - Disabled in tests
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_REGISTER=0.5
RECAPTCHA_SCORE_LOGIN=0.3

# Password Reset Token Configuration (M007)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10

# =============================================================================
# Phase 7: Audit Logging and Security
# =============================================================================

# Logging Configuration (uses tmp directory for tests)
LOG_DIR=/tmp/test_logs
LOG_LEVEL=WARNING
LOG_JSON_FORMAT=False
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=2

# Audit Log Retention (H7)
AUDIT_LOG_RETENTION_DAYS=30

# Concurrent Session Management (M7)
MAX_CONCURRENT_SESSIONS_PER_USER=5
SESSION_IDLE_TIMEOUT_HOURS=24

# Failed Login Tracking (M9)
FAILED_LOGIN_LOCKOUT_ENABLED=True

# Suspicious Activity Detection (M10) - Disabled in tests
SECURITY_EMAIL_FROM=security@test.localhost
KNOWN_IP_RETENTION_DAYS=30
ALERT_ON_NEW_LOCATION_LOGIN=False
ALERT_ON_PASSWORD_CHANGE=False
ALERT_ON_2FA_CHANGE=False
ALERT_ON_ACCOUNT_LOCKOUT=False
