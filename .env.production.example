# Production Environment Variables
# Copy to .env.production and update values
# NEVER commit actual values to version control

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=generate-a-very-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# Database (AWS RDS or Digital Ocean)
DATABASE_URL=postgres://user:password@host:5432/backend_template_prod

# Redis (Managed service)
REDIS_URL=redis://user:password@host:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=errors@example.com

# GraphQL
GRAPHQL_DEBUG=False

# =============================================================================
# Sentry Error Tracking, Logging, Profiling, and Metrics
# =============================================================================
# CRITICAL: Configure Sentry for production error monitoring
# Get DSN from: Sentry Dashboard > Settings > Projects > [Your Project] > Client Keys (DSN)

# REQUIRED: Your Sentry Data Source Name (DSN)
# Format: https://<public-key>@o<org-id>.ingest.sentry.io/<project-id>
SENTRY_DSN=https://your-public-key@o123456.ingest.sentry.io/your-project-id

# Environment identifier shown in Sentry dashboard
SENTRY_ENVIRONMENT=production

# Release version for tracking deployments
# IMPORTANT: Set this in CI/CD to your git tag (e.g., v0.7.0) or commit hash
# This enables release tracking, regression detection, and deploy notifications
SENTRY_RELEASE=

# Include request headers, IP addresses, and user info in error reports
# See: https://docs.sentry.io/platforms/python/data-management/data-collected/
# WARNING: Ensure this complies with your privacy policy and GDPR requirements
SENTRY_SEND_PII=True

# Enable sending Python logs to Sentry
SENTRY_ENABLE_LOGS=True

# Logging levels (Python logging levels: DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50)
# SENTRY_LOG_LEVEL: Minimum level to capture as breadcrumbs (context for errors)
# SENTRY_EVENT_LEVEL: Minimum level to create Sentry events (alerts)
SENTRY_LOG_LEVEL=20
SENTRY_EVENT_LEVEL=40

# Performance Monitoring: Transaction sampling rate (0.0 to 1.0)
# PRODUCTION TIP: Start with 1.0, reduce if volume is too high
# 1.0 = capture 100% of transactions, 0.1 = 10%
SENTRY_TRACES_SAMPLE_RATE=1.0

# Profiling: Profile session sampling rate (0.0 to 1.0)
# PRODUCTION TIP: 1.0 is fine for most apps, reduce if performance impacted
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0

# Profile lifecycle: "trace" runs profiler during active transactions
SENTRY_PROFILE_LIFECYCLE=trace

# Cloud Storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_AGE=3600

# Rate Limiting (requests per minute)
# Production values - more restrictive than development
RATELIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATELIMIT_GRAPHQL_MUTATION_REQUESTS_PER_MINUTE=30
RATELIMIT_GRAPHQL_QUERY_REQUESTS_PER_MINUTE=100
RATELIMIT_API_REQUESTS_PER_MINUTE=60
RATELIMIT_DEFAULT_REQUESTS_PER_MINUTE=120

# IP Allowlist for Admin Areas (CRITICAL in production)
# Comma-separated list of IPs or CIDR ranges allowed to access admin panels
# Example: "203.0.113.5,198.51.100.0/24"
# IMPORTANT: Configure this to restrict admin access to known IP addresses
ADMIN_ALLOWED_IPS=

# Protected paths for IP allowlist (comma-separated)
# Default: "/admin/,/cms/admin/,/api/admin/"
# Uncomment to customize:
# IP_ALLOWLIST_PROTECTED_PATHS="/admin/,/cms/admin/,/api/admin/"

# GraphQL Security
GRAPHQL_MAX_QUERY_DEPTH=10
GRAPHQL_MAX_QUERY_COMPLEXITY=1000
GRAPHQL_ENABLE_INTROSPECTION=False

# Encryption and Signing Keys - C1, C2 Security Requirements
# TOKEN_SIGNING_KEY: HMAC-SHA256 key for token hashing (C1 requirement)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SIGNING_KEY=

# TOTP_ENCRYPTION_KEY: Fernet key for 2FA secrets (C2 requirement)
# IP_ENCRYPTION_KEY: Fernet key for IP address encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICAL: Use DIFFERENT keys for each environment and keep them EXTREMELY secure
# NEVER commit actual keys to version control
# Store in environment variables or secure secret management system (AWS Secrets Manager, HashiCorp Vault)
TOTP_ENCRYPTION_KEY=
IP_ENCRYPTION_KEY=

# ClickUp Project Management Integration
# Get your API key from: https://app.clickup.com/settings/apps
# NEVER commit actual values - keep them in .env.production (gitignored)
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_SPACE_ID=
CLICKUP_BACKLOG_FOLDER_ID=
CLICKUP_SPRINT_FOLDER_ID=
CLICKUP_BACKLOG_LIST_ID=

# Phase 4: Security Hardening - Password & Bot Protection

# HaveIBeenPwned Integration (C001) - Password Breach Detection
# CRITICAL: Keep enabled in production to prevent compromised passwords
HIBP_API_ENABLED=true
HIBP_BREACH_THRESHOLD=1

# reCAPTCHA v3 (M001) - Bot Protection
# CRITICAL: Must be enabled in production to prevent automated attacks
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_ENABLED=true
RECAPTCHA_SITE_KEY=your-production-site-key
RECAPTCHA_SECRET_KEY=your-production-secret-key
RECAPTCHA_SCORE_REGISTER=0.5
RECAPTCHA_SCORE_LOGIN=0.3

# Password Reset Token Configuration (M007)
# Token expiry in minutes (10 minutes for production security)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=10

# =============================================================================
# Phase 7: Audit Logging and Security
# =============================================================================

# Logging Configuration
# Directory for log files (auth.log, mail.log, database.log, security.log, graphql.log, app.log)
# Ensure this directory exists and has appropriate permissions
LOG_DIR=/var/log/app
LOG_LEVEL=INFO
# CRITICAL: Use JSON format in production for log aggregation tools (ELK, Splunk, Datadog)
LOG_JSON_FORMAT=True
# Log file rotation settings (10MB per file, keep 10 backups for longer retention)
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Audit Log Retention (H7)
# Number of days to keep audit logs before archiving/deletion
# IMPORTANT: Ensure this meets your compliance requirements (GDPR, SOC2, etc.)
AUDIT_LOG_RETENTION_DAYS=365

# Concurrent Session Management (M7)
# Maximum number of active sessions per user
# Lower values provide better security but may inconvenience users with many devices
MAX_CONCURRENT_SESSIONS_PER_USER=5
# Session idle timeout in hours (shorter = more secure)
SESSION_IDLE_TIMEOUT_HOURS=12

# Failed Login Tracking (M9)
# Progressive lockout with exponential backoff
# CRITICAL: Keep enabled to prevent brute force attacks
FAILED_LOGIN_LOCKOUT_ENABLED=True

# Suspicious Activity Detection (M10)
# Email address used for security alert notifications
# IMPORTANT: Use a monitored security team email address
SECURITY_EMAIL_FROM=security@example.com
# Number of days to remember known IP addresses for new location detection
KNOWN_IP_RETENTION_DAYS=90

# CRITICAL: All security alerts should be enabled in production
ALERT_ON_NEW_LOCATION_LOGIN=True
ALERT_ON_PASSWORD_CHANGE=True
ALERT_ON_2FA_CHANGE=True
ALERT_ON_ACCOUNT_LOCKOUT=True
