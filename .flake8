[flake8]
max-line-length = 100
extend-ignore = E203, E501, W503, C901, E226
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    .env,
    migrations,
    node_modules,
    build,
    dist,
    *.egg-info,
    .claude/plugins/*,
    scripts/clickup/*,
    tests/bdd/step_defs/*
per-file-ignores =
    __init__.py:F401
    */settings/*.py:F403,F405
    api/security.py:C901
    */security.py:C901
