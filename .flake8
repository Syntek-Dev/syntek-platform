[flake8]
# Base settings
max-line-length = 100
max-complexity = 10

# Exclude paths
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    ENV,
    env,
    .eggs,
    *.egg,
    build,
    dist,
    .tox,
    .nox,
    migrations,
    node_modules,
    staticfiles,
    media,
    docs

# Ignore specific errors
ignore =
    # E203: whitespace before ':' (conflicts with black)
    E203,
    # E501: line too long (handled by black)
    E501,
    # W503: line break before binary operator (conflicts with black)
    W503,
    # E402: module level import not at top of file (Django settings)
    E402,
    # F401: imported but unused (sometimes needed for Django)
    # F401,

# Per-file ignores
per-file-ignores =
    __init__.py:F401,
    settings/*.py:E402,F405,F403

# Import order settings
import-order-style = google
application-import-names = backend,apps

# Docstring settings
docstring-convention = google

# Enable plugins
# flake8-bugbear, flake8-django, flake8-docstrings
select = B,C,E,F,W,B9,D
