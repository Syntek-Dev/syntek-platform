# direnv configuration for automatic environment activation
# Install direnv: https://direnv.net/

# Load environment-specific .env file based on DJANGO_ENV
if [ -z "$DJANGO_ENV" ]; then
    export DJANGO_ENV="dev"
fi

# Activate Python virtual environment
if [ -d ".venv" ]; then
    source .venv/bin/activate
elif [ -d "venv" ]; then
    source venv/bin/activate
fi

# Load environment variables
if [ -f ".env.${DJANGO_ENV}" ]; then
    dotenv .env.${DJANGO_ENV}
fi

# Set Django settings module
export DJANGO_SETTINGS_MODULE="config.settings.${DJANGO_ENV}"

# Add project to Python path
export PYTHONPATH="${PWD}:${PYTHONPATH}"

# Display loaded environment
echo "Environment: ${DJANGO_ENV}"
echo "Django Settings: ${DJANGO_SETTINGS_MODULE}"
